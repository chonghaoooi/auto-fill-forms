{
  "manifest_version": 3,
  "name": "Local Form Autofill",
  "description": "Autofill Google Forms and Microsoft Forms from a local profile.",
  "version": "0.2.0",
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://docs.google.com/forms/*",
    "https://forms.office.com/*"
  ],
  "background": {
    "service_worker": "dist/background.js"
  },
  "action": {
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    },
    "default_popup": "src/popup.html",
    "default_title": "Form Autofill"
  },
  "content_scripts": [
    {
      "matches": [
        "https://docs.google.com/forms/*",
        "https://forms.office.com/*"
      ],
      "js": ["dist/defaults.js", "dist/content.js"],
      "run_at": "document_idle"
    }
  ]
}
